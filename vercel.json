{
  "rewrites": [
    {
      "source": "/api/sync-crew-user-assignments",
      "destination": "/api/sync-crew-user?route=assignments"
    },
    {
      "source": "/api/sync-crew-user-contracts",
      "destination": "/api/sync-crew-user?route=contracts"
    },
    {
      "source": "/api/expenses/recalc",
      "destination": "/api/expenses/sync?route=recalc"
    },
    {
      "source": "/api/pos/pull-from-flex",
      "destination": "/api/contacts/pull-from-flex?route=pos"
    },
    {
      "source": "/api/contacts/geocode-new",
      "destination": "/api/contacts/pull-from-flex?route=geocode"
    }
  ],
  "functions": {
    "api/calculate-route-mileage.js": {
      "maxDuration": 60
    },
    "api/generate-bol.js": {
      "maxDuration": 60
    },
    "api/create-project-from-quote.js": {
      "maxDuration": 60
    },
    "api/bulk-import-upcoming.js": {
      "maxDuration": 60
    },
    "api/contracts/generate.js": {
      "maxDuration": 60
    },
    "api/contacts/push-to-flex.js": {
      "maxDuration": 60
    },
    "api/contacts/pull-from-flex.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/bulk-import-upcoming",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/contacts/pull-from-flex",
      "schedule": "5 11 * * *"
    },
    {
      "path": "/api/pos/pull-from-flex",
      "schedule": "15 11 * * *"
    }
  ]
}
