{
  "rewrites": [
    { "source": "/api/sync-crew-user-assignments", "destination": "/api/sync-crew-user?route=assignments" },
    { "source": "/api/sync-crew-user-contracts", "destination": "/api/sync-crew-user?route=contracts" },
    { "source": "/api/expenses/recalc", "destination": "/api/expenses/sync?route=recalc" }
  ],
  "functions": {
    "api/calculate-route-mileage.js":  { "maxDuration": 60 },
    "api/generate-bol.js":             { "maxDuration": 60 },
    "api/create-project-from-quote.js":{ "maxDuration": 60 },
    "api/bulk-import-upcoming.js":     { "maxDuration": 60 },
    "api/contracts/generate.js":       { "maxDuration": 60 },
    "api/contacts/push-to-flex.js":    { "maxDuration": 30 },
    "api/contacts/pull-from-flex.js":  { "maxDuration": 60 },
    "api/contacts/dedup.js":           { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/bulk-import-upcoming",    "schedule": "0 14 * * *" },
    { "path": "/api/contacts/pull-from-flex", "schedule": "5 14 * * *" }
  ]
}
